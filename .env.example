# =============================================================================
# fbclone — Environment Variables (copy to .env and fill in)
# =============================================================================

# ----- Core -----------------------------------------------------------------
NODE_ENV=development
# Public URL of the web app and API (used for CORS, email links, cookies)
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ----- Database (PostgreSQL) -------------------------------------------------
POSTGRES_USER=fbclone
POSTGRES_PASSWORD=fbclone_dev_password
POSTGRES_DB=fbclone
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://fbclone:fbclone_dev_password@localhost:5432/fbclone?schema=public"

# ----- Redis (cache, sessions, rate-limit, socket adapter) -------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL="redis://localhost:6379"
# Set to false to run without Redis (in-memory rate limiting + no-op cache).
REDIS_ENABLED=true

# ----- JWT / Auth ------------------------------------------------------------
# Use long random strings in production: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d
# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECRET=change_me_cookie_signing_secret

# ----- Email (SMTP) ----------------------------------------------------------
# In dev, leave SMTP_HOST empty to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Orbit <no-reply@orbit.app>"

# ----- Two-Factor Auth (TOTP) ------------------------------------------------
TOTP_ISSUER=Orbit

# ----- Object Storage (AWS S3 compatible: AWS, MinIO, R2, etc.) --------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=fbclone-media
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/fbclone-media

# ----- Rate Limiting ---------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ----- Frontend (Next.js public vars) ---------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# WebRTC ICE servers for voice/video calls. STUN alone works on LAN/open
# networks; a TURN server is required for calls across restrictive NATs.
# NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# ----- Observability ---------------------------------------------------------
LOG_LEVEL=debug
